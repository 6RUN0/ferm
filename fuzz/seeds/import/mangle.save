# Generated by iptables-save
*mangle
:PREROUTING ACCEPT [0:0]
:INPUT ACCEPT [0:0]
:FORWARD ACCEPT [0:0]
:OUTPUT ACCEPT [0:0]
:POSTROUTING ACCEPT [0:0]
-A PREROUTING -p tcp -m tcp --tcp-flags SYN,RST SYN -j TCPMSS --clamp-mss-to-pmtu
-A FORWARD -m mark --mark 0x1 -j ACCEPT
-A OUTPUT -p tcp -m tcp --dport 25 -j MARK --set-mark 0x2
-A POSTROUTING ! -s 192.0.2.0/24 -j TOS --set-tos 0x10
COMMIT
