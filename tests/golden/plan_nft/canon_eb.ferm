domain eb {
    table filter {
        chain INPUT {
            policy ACCEPT;
            proto tcp dport 22 ACCEPT;
        }
        chain FORWARD policy DROP;
        chain OUTPUT policy ACCEPT;
    }
    table raw {
        chain PREROUTING {
            policy ACCEPT;
            proto tcp dport 80 ACCEPT;
        }
        chain OUTPUT policy ACCEPT;
    }
}
