add table ip ferm
flush table ip ferm
add set ip ferm x { type ipv4_addr; }
add element ip ferm x { 10.0.0.1, 10.0.0.2 }
add chain ip ferm INPUT { type filter hook input priority 0; }
add rule ip ferm INPUT ip saddr @x accept
add table ip6 ferm
flush table ip6 ferm
add chain ip6 ferm INPUT { type filter hook input priority 0; }
