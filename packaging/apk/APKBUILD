# Maintainer: Boris Talovikov <boris@talovikov.ru>
#
# APKBUILD for the ferm Python port (pyferm) -- the Alpine counterpart of the
# native .deb (packaging/deb/) and .rpm (packaging/rpm/). A noarch python
# package that drops in for the upstream Perl "ferm" (same /usr/bin/ferm and
# /usr/bin/import-ferm), ships a starter /etc/ferm/ferm.conf and an OpenRC
# service that is deliberately NOT added to a runlevel on install (anti-lockout).
#
# Build model (mirrors the .deb/.rpm seed-and-rewrite): this APKBUILD carries a
# 0.0.0 pkgver seed; the build driver (packaging/build.py, nox session
# build_apk) rewrites pkgver from the release tag and exports the FULL PEP 440
# version as SETUPTOOLS_SCM_PRETEND_VERSION so hatch-vcs freezes the right
# version into the wheel METADATA (the source tarball carries no .git). The
# pkgver here is the apk-sanitized form (PEP 440 pre-release markers as Alpine
# _alpha/_beta/_rc suffixes); the PEP 440 string is fed to hatch-vcs separately.
#
# apk has no "Recommends": the optional integrations the .deb/.rpm recommend
# (nftables for the --nft backend, py3-dnspython for @resolve()'s non-A records,
# etckeeper to version /etc) are NOT declared here. nftables and the dnspython
# stdlib fallback work without them; install the extras explicitly if wanted.
pkgname=pyferm
pkgver=0.0.0
pkgrel=0
pkgdesc="For Easy Rule Making -- iptables/nftables frontend (Python port)"
url="https://github.com/6RUN0/ferm"
arch="noarch"
license="GPL-2.0-or-later"
# ferm shells out to iptables/iptables-restore (and ip6tables), and the wheel's
# console scripts need a python3 interpreter -- Alpine's base image carries none
# and abuild adds no interpreter dependency for a non-py3-* package (scanelf
# only traces ELF SONAMEs), so it must be declared explicitly or the package is
# dead on arrival. "!ferm" refuses to coexist with the upstream Perl ferm (the
# apk conflict idiom, analog of the .deb/.rpm "Conflicts: ferm"; both own
# /usr/bin/ferm). See the no-Recommends note above for the optionals.
depends="iptables python3 !ferm"
makedepends="
	python3
	py3-gpep517
	py3-installer
	py3-hatchling
	py3-hatch-vcs
	py3-setuptools_scm
	"
# Drop-in for the upstream Perl "ferm": provide its name so dependents resolve.
# Coexistence is refused by depends="!ferm" above (the two cannot be installed
# together), so there is no `replaces` tiebreaker to set -- it would be inert
# under "!ferm" and never fire. Migration from the Perl ferm is therefore an
# explicit `apk del ferm && apk add pyferm` (mirrors the rpm spec's honest
# note), the apk analog of the .deb/.rpm Provides/Conflicts.
provides="ferm=$pkgver-r$pkgrel"
# Posture-downgrade breadcrumb on install; cleanup on removal.
install="$pkgname.post-install $pkgname.post-deinstall"
source="$pkgname-$pkgver.tar.gz
	ferm.initd
	"
# No check() function: the test suite runs in the project's nox sessions, not at
# package build time (the build container has no test deps).
options="!check"
builddir="$srcdir/$pkgname-$pkgver"

build() {
	cd "$builddir"
	# The driver exports the full PEP 440 version; fall back to pkgver for a
	# manual `abuild` run (apk-sanitized, but enough to not freeze 0.0.0).
	export SETUPTOOLS_SCM_PRETEND_VERSION="${SETUPTOOLS_SCM_PRETEND_VERSION:-$pkgver}"
	gpep517 build-wheel --wheel-dir .dist --output-fd 3 3>&1 >&2
}

package() {
	cd "$builddir"
	python3 -m installer -d "$pkgdir" .dist/*.whl

	# Starter config (apk auto-protects /etc files on upgrade via .apk-new) and
	# the empty drop-in fragment dir. Single source of truth is
	# packaging/deb/ferm.conf, shared with the .deb/.rpm; rewrite the systemd
	# opt-in hint to the OpenRC equivalent for Alpine users.
	install -Dm644 packaging/deb/ferm.conf "$pkgdir"/etc/ferm/ferm.conf
	sed -i \
		's|systemctl enable --now ferm|rc-update add ferm boot \&\& rc-service ferm start|' \
		"$pkgdir"/etc/ferm/ferm.conf
	install -dm755 "$pkgdir"/etc/ferm/ferm.d

	# OpenRC service, installed but NOT added to a runlevel (anti-lockout): apk
	# never wires a service in, so this ships --no-enable by construction.
	install -Dm755 "$srcdir"/ferm.initd "$pkgdir"/etc/init.d/ferm

	# The throttle example under examples/ (matches the .deb/.rpm doc layout);
	# ferm.conf points users at /usr/share/doc/pyferm/examples/.
	install -Dm644 packaging/deb/examples/ssh-throttle.conf.example \
		"$pkgdir"/usr/share/doc/pyferm/examples/ssh-throttle.conf.example

	# Ship the license for cross-format parity with the rpm (%license COPYING)
	# and the deb (debian/copyright); GPL-2.0-or-later requires the text travel
	# with the package.
	install -Dm644 COPYING "$pkgdir"/usr/share/licenses/$pkgname/COPYING
}

sha512sums="" # regenerated by `abuild checksum` in the build container
