[Unit]
Description=for Easy Rule Making (load firewall rules)
Documentation=man:ferm(1)
Before=network-pre.target
Wants=network-pre.target

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/bin/ferm /etc/ferm/ferm.conf
ExecReload=/usr/bin/ferm /etc/ferm/ferm.conf
ExecStop=/usr/bin/ferm -F /etc/ferm/ferm.conf

[Install]
WantedBy=multi-user.target
